# .env.example
# Copy to .env and adjust. chmod 600 .env
# This file is for LOCAL USE ONLY - no real secrets needed for offline LLM

# ── Paths ────────────────────────────────────────────────────────────────────
# Absolute path to this project root
PROJECT_ROOT=/work1/llm-local-agent

# Path to the git repository you want to work on
WORKSPACE_PATH=/work1/gmpxx_mkII/

# ── Model ───────────────────────────────────────────────────────────────────
MODEL_FILE=Qwen3.5-35B-A3B-Q4_K_M.gguf
AIDER_MODEL_NAME=Qwen3.5-35B-A3B

# ── llama-server settings ────────────────────────────────────────────────────
LLAMA_CPP_VERSION=HEAD
LLAMA_CTX_SIZE=262144
LLAMA_BATCH_SIZE=512

# Temperature for coding tasks: lower = more deterministic
# Qwen3.5 best practices recommend 0.6 for general, lower for coding
LLM_TEMPERATURE=0.4
LLM_TOP_P=0.95

# ── aider settings ───────────────────────────────────────────────────────────
AIDER_VERSION=0.85.2
AIDER_NO_AUTO_COMMITS=false

# ── "API key" - only for local compatibility; no real auth ──────────────────
# llama-server does not check this. aider requires a non-empty value.
OPENAI_API_KEY=local-no-auth-required

# ── Secrets pattern (if your repo build needs tokens etc.) ──────────────────
# Store real secrets in ./secrets/ (git-ignored, chmod 600)
# Mount as: - ./secrets/mysecret.env:/run/secrets/mysecret:ro
# Then in container: cat /run/secrets/mysecret
# NEVER put real credentials in this .env.example
# MY_GITHUB_TOKEN=  # example placeholder only
