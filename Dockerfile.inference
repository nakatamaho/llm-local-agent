# Dockerfile.inference
# llama.cpp server - statically linked (no .so dependency issues at runtime)
# CUDA device code is still dynamic (nvidia driver), but all userspace libs are static.

FROM nvidia/cuda:12.4.1-devel-ubuntu22.04 AS builder

ARG LLAMA_CPP_VERSION=b5576

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    cmake \
    build-essential \
    libcurl4-openssl-dev \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*
# Note: libgomp.a (static OpenMP) is already included in build-essential via gcc

WORKDIR /build

RUN git clone https://github.com/ggerganov/llama.cpp.git \
    && cd llama.cpp \

RUN set -eux; \
    CUDA_STUBS=""; \
    for d in /usr/local/cuda/targets/*/lib/stubs /usr/local/cuda/lib64/stubs; do \
        if [ -d "$d" ] && [ -f "$d/libcuda.so" ]; then CUDA_STUBS="$d"; break; fi; \
    done; \
    ln -sf "$CUDA_STUBS/libcuda.so" "$CUDA_STUBS/libcuda.so.1"; \
    \
    cd llama.cpp; \
    cmake -B build \
        -DGGML_CUDA=ON \
        -DGGML_CUDA_F16=ON \
        -DGGML_OPENMP=OFF \
        -DLLAMA_CURL=OFF \
        -DBUILD_SHARED_LIBS=OFF \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_EXE_LINKER_FLAGS="-static-libgcc -static-libstdc++ -Wl,-rpath-link,${CUDA_STUBS}" \
        -DCMAKE_SHARED_LINKER_FLAGS="-Wl,-rpath-link,${CUDA_STUBS}"; \
    cmake --build build -j"$(nproc)" --target llama-server; \
    \
    echo "=== Dynamic deps of llama-server ===" ; \
    ldd build/bin/llama-server

# ---- Runtime image (minimal) ----
FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/llama.cpp/build/bin/llama-server /usr/local/bin/llama-server

RUN useradd -m -u 1000 -s /bin/bash llmuser
USER llmuser

WORKDIR /models
EXPOSE 8080

ENTRYPOINT ["llama-server"]
CMD [ \
    "--model", "/models/Qwen3.5-35B-A3B-Q4_K_M.gguf", \
    "--host", "0.0.0.0", \
    "--port", "8080", \
    "-ngl", "99", \
    "--ctx-size", "65536", \
    "--batch-size", "512", \
    "--ubatch-size", "256", \
    "--n-predict", "-1", \
    "--threads", "8", \
    "--flash-attn", \
    "--cache-type-k", "q8_0", \
    "--cache-type-v", "q8_0", \
    "--log-disable" \
]
