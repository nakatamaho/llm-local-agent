# Dockerfile.agent
# aider CLI coding agent - connects to llama-server via internal network
# No GPU needed

FROM python:3.12-slim-bookworm

ARG AIDER_VERSION=0.85.2
# Pinned delta (git diff pager) version from upstream releases
ARG DELTA_VERSION=0.18.2

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    universal-ctags \
    ripgrep \
    patch \
    curl \
    ca-certificates \
    build-essential \
    gzip \
    && rm -rf /var/lib/apt/lists/*

# Install delta (syntax-highlighting pager for git/diff output).
# Debian bookworm does not ship the "git-delta" package, so install the official release tarball.
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "${arch}" in \
        amd64) target="x86_64-unknown-linux-gnu" ;; \
        arm64) target="aarch64-unknown-linux-gnu" ;; \
        armhf) target="arm-unknown-linux-gnueabihf" ;; \
        i386)  target="i686-unknown-linux-gnu" ;; \
        *) echo "Unsupported architecture for delta: ${arch}" >&2; exit 1 ;; \
    esac; \
    url="https://github.com/dandavison/delta/releases/download/${DELTA_VERSION}/delta-${DELTA_VERSION}-${target}.tar.gz"; \
    curl -fsSL "${url}" -o /tmp/delta.tar.gz; \
    tar -C /tmp -xzf /tmp/delta.tar.gz; \
    install -m 0755 "/tmp/delta-${DELTA_VERSION}-${target}/delta" /usr/local/bin/delta; \
    rm -rf /tmp/delta*; \
    delta --version

# Install aider at pinned version
RUN pip install --no-cache-dir "aider-chat==${AIDER_VERSION}"

# Create non-root user
RUN useradd -m -u 1000 -s /bin/bash agentuser
USER agentuser
WORKDIR /workspace

# Aider config dir
RUN mkdir -p /home/agentuser/.aider

# Default: drop into interactive shell so user can run aider manually
# Override CMD in docker-compose or docker run for specific tasks
CMD ["/bin/bash"]
